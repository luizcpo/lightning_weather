<div class="rounded-2xl border-2 border-dashed border-slate-200 bg-white/60 p-10 text-center">
  <div class="mx-auto inline-flex h-16 w-16 items-center justify-center rounded-2xl bg-gradient-to-br from-indigo-100 to-sky-100 text-indigo-500">
    <%= icon "map-pin", class: "h-8 w-8" %>
  </div>
  <h3 class="mt-3 text-lg font-semibold text-slate-900">Search any address to start</h3>
  <p class="mt-1 text-sm text-slate-500 max-w-md mx-auto">
    We'll look up the ZIP code, fetch the forecast from Open-Meteo, and cache the result for 30 minutes.
  </p>
</div>
