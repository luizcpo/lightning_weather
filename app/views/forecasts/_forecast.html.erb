<%# locals: (forecast:) %>
<article class="overflow-hidden rounded-2xl bg-white shadow-xl shadow-slate-900/5 ring-1 ring-slate-900/5">
  <header class="flex flex-wrap items-start justify-between gap-3 bg-gradient-to-r from-indigo-600 to-sky-500 px-6 sm:px-8 py-6 text-white">
    <div class="min-w-0">
      <p class="text-sm uppercase tracking-wider text-indigo-100">Forecast for</p>
      <h2 class="text-xl sm:text-2xl font-semibold truncate"><%= forecast.formatted_address %></h2>
      <p class="text-sm text-indigo-100 mt-1">
        <% if forecast.zip_code.present? %>
          ZIP <span class="font-mono"><%= forecast.zip_code %></span>
          <% if forecast.timezone.present? %>· <%= forecast.timezone %><% end %>
        <% elsif forecast.timezone.present? %>
          <%= forecast.timezone %>
        <% end %>
      </p>
    </div>

    <% if forecast.from_cache? %>
      <span class="inline-flex items-center gap-1.5 rounded-full bg-amber-300/95 px-3 py-1 text-xs font-semibold text-amber-900 shadow"
            title="Served from cache (refreshes every 30 minutes)">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4">
          <path fill-rule="evenodd" d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm.75-13a.75.75 0 0 0-1.5 0v5c0 .2.08.39.22.53l3 3a.75.75 0 1 0 1.06-1.06l-2.78-2.78V5Z" clip-rule="evenodd" />
        </svg>
        From cache
      </span>
    <% else %>
      <span class="inline-flex items-center gap-1.5 rounded-full bg-emerald-400/95 px-3 py-1 text-xs font-semibold text-emerald-900 shadow"
            title="Freshly retrieved from the weather provider">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-4 w-4">
          <path fill-rule="evenodd" d="M15.312 11.424a5.5 5.5 0 0 1-9.201 2.466l-.312-.311h2.433a.75.75 0 0 0 0-1.5H3.989a.75.75 0 0 0-.75.75v4.242a.75.75 0 0 0 1.5 0v-2.43l.31.31a7 7 0 0 0 11.712-3.138.75.75 0 0 0-1.449-.39ZM3.5 8.624a5.5 5.5 0 0 1 9.201-2.466l.31.311h-2.432a.75.75 0 0 0 0 1.5h4.243a.75.75 0 0 0 .75-.75V2.977a.75.75 0 0 0-1.5 0v2.43l-.311-.31a7 7 0 0 0-11.711 3.139.75.75 0 0 0 1.45.388Z" clip-rule="evenodd" />
        </svg>
        Live
      </span>
    <% end %>
  </header>

  <div class="grid gap-8 p-6 sm:p-8 md:grid-cols-[minmax(0,1fr)_minmax(0,1fr)] md:items-center">
    <div class="flex items-center gap-5">
      <div class="text-7xl leading-none" aria-hidden="true">
        <%= weather_icon_for(forecast.current_weather_code) %>
      </div>
      <div>
        <div class="flex items-baseline gap-2">
          <span class="text-6xl font-extralight tracking-tight text-slate-900">
            <%= format_temperature(forecast.current_temperature, "") %>
          </span>
          <span class="text-2xl text-slate-500"><%= forecast.temperature_unit %></span>
        </div>
        <p class="mt-1 text-lg text-slate-600">
          <%= weather_label_for(forecast.current_weather_code) %>
        </p>
        <% if forecast.current_feels_like.present? %>
          <p class="text-sm text-slate-500">
            Feels like <%= format_temperature(forecast.current_feels_like, forecast.temperature_unit) %>
          </p>
        <% end %>
      </div>
    </div>

    <dl class="grid grid-cols-2 gap-4 text-sm">
      <% if forecast.today.present? %>
        <div class="rounded-xl bg-slate-50 p-4 ring-1 ring-slate-100">
          <dt class="text-slate-500">Today's high</dt>
          <dd class="mt-1 text-2xl font-semibold text-slate-900">
            <%= format_temperature(forecast.today[:temperature_max], forecast.temperature_unit) %>
          </dd>
        </div>
        <div class="rounded-xl bg-slate-50 p-4 ring-1 ring-slate-100">
          <dt class="text-slate-500">Today's low</dt>
          <dd class="mt-1 text-2xl font-semibold text-slate-900">
            <%= format_temperature(forecast.today[:temperature_min], forecast.temperature_unit) %>
          </dd>
        </div>
      <% end %>
      <div class="rounded-xl bg-slate-50 p-4 ring-1 ring-slate-100">
        <dt class="text-slate-500">Humidity</dt>
        <dd class="mt-1 text-2xl font-semibold text-slate-900">
          <%= forecast.current_humidity ? "#{forecast.current_humidity}%" : "—" %>
        </dd>
      </div>
      <div class="rounded-xl bg-slate-50 p-4 ring-1 ring-slate-100">
        <dt class="text-slate-500">Wind</dt>
        <dd class="mt-1 text-2xl font-semibold text-slate-900">
          <%= forecast.current_wind_speed ? "#{forecast.current_wind_speed} #{forecast.speed_unit}" : "—" %>
        </dd>
      </div>
    </dl>
  </div>

  <% if forecast.daily_forecasts.any? %>
    <div class="border-t border-slate-100 px-6 sm:px-8 py-6">
      <h3 class="text-sm font-semibold uppercase tracking-wider text-slate-500 mb-4">
        7-day outlook
      </h3>
      <ol class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-7 gap-3">
        <% forecast.daily_forecasts.each_with_index do |day, index| %>
          <li class="rounded-xl bg-slate-50/80 ring-1 ring-slate-100 p-3 text-center">
            <p class="text-xs font-semibold uppercase tracking-wider text-slate-500">
              <%= index.zero? ? "Today" : format_day(day[:date], format: :short) %>
            </p>
            <p class="text-xs text-slate-400 mb-2"><%= format_day(day[:date], format: :date) %></p>
            <div class="text-3xl" aria-label="<%= weather_label_for(day[:weather_code]) %>">
              <%= weather_icon_for(day[:weather_code]) %>
            </div>
            <p class="mt-2 text-sm">
              <span class="font-semibold text-slate-900">
                <%= format_temperature(day[:temperature_max], "°") %>
              </span>
              <span class="text-slate-400">
                / <%= format_temperature(day[:temperature_min], "°") %>
              </span>
            </p>
            <% if day[:precipitation_probability].present? && day[:precipitation_probability] > 0 %>
              <p class="mt-1 text-xs text-sky-600">
                💧 <%= day[:precipitation_probability] %>%
              </p>
            <% end %>
          </li>
        <% end %>
      </ol>
    </div>
  <% end %>

  <footer class="bg-slate-50 px-6 sm:px-8 py-3 text-xs text-slate-500 flex flex-wrap justify-between gap-2">
    <span>
      <% if forecast.retrieved_at.present? %>
        Retrieved <%= time_ago_in_words(forecast.retrieved_at) %> ago
      <% end %>
    </span>
    <span>Cached for 30 minutes per ZIP code</span>
  </footer>
</article>
