<%# locals: (address: nil, unit_system: "imperial") %>
<div class="rounded-2xl bg-white shadow-xl shadow-slate-900/5 ring-1 ring-slate-900/5 p-6 sm:p-8 mb-8">
  <%= form_with url: forecast_path,
                method: :get,
                data: {
                  controller: "places-autocomplete loading",
                  loading_frame_value: "forecast_result",
                  action: "submit->loading#showSkeleton",
                  turbo_frame: "forecast_result",
                  turbo_action: "advance"
                },
                class: "space-y-4" do |form| %>

    <div class="flex flex-col gap-2">
      <%= form.label :address, "Address or city", class: "text-sm font-medium text-slate-700" %>
      <div class="relative">
        <span class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-4 text-slate-400">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-5 w-5">
            <path fill-rule="evenodd" d="m9.69 18.933.003.001C9.89 19.02 10 19 10 19s.11.02.308-.066l.002-.001.006-.003.018-.008a5.74 5.74 0 0 0 .281-.14c.186-.096.446-.24.757-.433.62-.384 1.445-.966 2.274-1.765C15.302 14.988 17 12.493 17 9A7 7 0 1 0 3 9c0 3.492 1.698 5.988 3.355 7.584a13.731 13.731 0 0 0 2.273 1.765 11.842 11.842 0 0 0 .976.544l.062.029.018.008.006.003ZM10 11.25a2.25 2.25 0 1 0 0-4.5 2.25 2.25 0 0 0 0 4.5Z" clip-rule="evenodd" />
          </svg>
        </span>
        <%= form.text_field :address,
              value: address,
              autocomplete: "off",
              placeholder: "e.g. 1600 Amphitheatre Parkway, Mountain View, CA",
              required: true,
              data: { places_autocomplete_target: "input" },
              class: "w-full rounded-xl border-0 bg-slate-50 py-3 pl-11 pr-11 text-base text-slate-900 ring-1 ring-inset ring-slate-200 placeholder:text-slate-400 focus:ring-2 focus:ring-indigo-500 focus:outline-none transition" %>
        <span data-places-autocomplete-target="spinner"
              hidden
              class="pointer-events-none absolute inset-y-0 right-0 flex items-center pr-4 text-indigo-500"
              aria-hidden="true">
          <svg class="h-5 w-5 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 0 1 8-8v4a4 4 0 0 0-4 4H4z"></path>
          </svg>
        </span>
      </div>
      <p class="text-xs text-slate-500">
        Autocomplete uses Google Places. Pick a suggestion for the most accurate result.
      </p>
    </div>

    <div class="flex flex-col-reverse sm:flex-row sm:items-center sm:justify-between gap-3">
      <fieldset class="flex items-center gap-1 rounded-xl bg-slate-100 p-1 text-sm font-medium">
        <legend class="sr-only">Temperature unit</legend>
        <% %w[imperial metric].each do |unit| %>
          <label class="cursor-pointer">
            <%= form.radio_button :unit_system, unit,
                  checked: unit_system == unit,
                  class: "peer sr-only",
                  data: { action: "change->loading#requestSubmit" } %>
            <span class="block rounded-lg px-3 py-1.5 text-slate-600 peer-checked:bg-white peer-checked:text-indigo-600 peer-checked:shadow transition">
              <%= unit == "imperial" ? "°F · mph" : "°C · km/h" %>
            </span>
          </label>
        <% end %>
      </fieldset>

      <%= form.submit "Get forecast",
            data: { turbo_submits_with: "Fetching forecast…" },
            class: "inline-flex items-center justify-center gap-2 rounded-xl bg-gradient-to-r from-indigo-600 to-sky-500 px-5 py-3 text-sm font-semibold text-white shadow-lg shadow-indigo-500/20 hover:shadow-indigo-500/40 hover:-translate-y-0.5 transition focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 disabled:opacity-70 disabled:cursor-progress disabled:hover:translate-y-0" %>
    </div>

    <%# Rendered into the turbo-frame on submit, then replaced by the real response. %>
    <template data-loading-target="template">
      <%= render "skeleton" %>
    </template>
  <% end %>
</div>
