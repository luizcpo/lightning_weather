<div role="status"
     aria-live="polite"
     aria-label="Fetching forecast"
     class="overflow-hidden rounded-2xl bg-white shadow-xl shadow-slate-900/5 ring-1 ring-slate-900/5 animate-pulse">
  <div class="flex flex-wrap items-start justify-between gap-3 bg-gradient-to-r from-indigo-200 to-sky-200 px-6 sm:px-8 py-6">
    <div class="space-y-2 flex-1 min-w-0">
      <div class="h-3 w-24 rounded-full bg-white/60"></div>
      <div class="h-5 w-3/4 rounded-full bg-white/80"></div>
      <div class="h-3 w-32 rounded-full bg-white/60"></div>
    </div>
    <div class="h-6 w-20 rounded-full bg-white/70"></div>
  </div>

  <div class="grid gap-8 p-6 sm:p-8 md:grid-cols-[minmax(0,1fr)_minmax(0,1fr)] md:items-center">
    <div class="flex items-center gap-5">
      <div class="h-20 w-20 rounded-2xl bg-slate-200"></div>
      <div class="space-y-3 flex-1">
        <div class="h-12 w-32 rounded-xl bg-slate-200"></div>
        <div class="h-4 w-24 rounded-full bg-slate-200"></div>
        <div class="h-3 w-32 rounded-full bg-slate-200"></div>
      </div>
    </div>
    <dl class="grid grid-cols-2 gap-4">
      <% 4.times do %>
        <div class="rounded-xl bg-slate-100 p-4 ring-1 ring-slate-100 space-y-2">
          <div class="h-3 w-16 rounded-full bg-slate-200"></div>
          <div class="h-6 w-12 rounded-lg bg-slate-200"></div>
        </div>
      <% end %>
    </dl>
  </div>

  <div class="border-t border-slate-100 px-6 sm:px-8 py-6">
    <div class="h-3 w-32 rounded-full bg-slate-200 mb-4"></div>
    <ol class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-7 gap-3">
      <% 7.times do %>
        <li class="rounded-xl bg-slate-50 ring-1 ring-slate-100 p-3 text-center space-y-2">
          <div class="h-3 w-12 rounded-full bg-slate-200 mx-auto"></div>
          <div class="h-2 w-10 rounded-full bg-slate-200 mx-auto"></div>
          <div class="h-8 w-8 rounded-full bg-slate-200 mx-auto my-1"></div>
          <div class="h-3 w-14 rounded-full bg-slate-200 mx-auto"></div>
        </li>
      <% end %>
    </ol>
  </div>

  <span class="sr-only">Loading forecast…</span>
</div>
