<% content_for :title, "Lightning Weather" %>

<section class="mx-auto max-w-3xl">
  <div class="text-center mb-10">
    <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-slate-900">
      What's the weather like?
    </h1>
    <p class="mt-3 text-lg text-slate-600">
      Type any address and we'll fetch the current conditions and a 7-day outlook.
    </p>
  </div>

  <%= render "search_form", address: @address, unit_system: @unit_system %>

  <%= turbo_frame_tag "forecast_result" do %>
    <% if @error.present? %>
      <%= render "error", message: @error %>
    <% elsif @forecast.present? %>
      <%= render "forecast", forecast: @forecast %>
    <% elsif @address.blank? %>
      <%= render "empty_state" %>
    <% end %>
  <% end %>
</section>
