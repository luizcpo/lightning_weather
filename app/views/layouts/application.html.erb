<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Lightning Weather" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <meta name="google-maps-api-key" content="<%= Rails.application.config.x.google_maps_api_key %>">

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen bg-gradient-to-br from-sky-50 via-white to-indigo-100 text-slate-800 antialiased">
    <header class="border-b border-slate-200/70 bg-white/70 backdrop-blur-md sticky top-0 z-30">
      <div class="container mx-auto flex items-center justify-between px-5 py-4">
        <a href="/" class="flex items-center gap-2 text-slate-900 hover:text-indigo-600 transition">
          <span class="inline-flex h-9 w-9 items-center justify-center rounded-xl bg-gradient-to-br from-indigo-500 to-sky-500 text-white shadow-md">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-5 w-5">
              <path fill-rule="evenodd" d="M11.3 1.046a1 1 0 0 1 .7 1.218L10.42 8.5H15a1 1 0 0 1 .8 1.6l-7 9a1 1 0 0 1-1.78-.864L8.58 11.5H4a1 1 0 0 1-.8-1.6l7-9a1 1 0 0 1 1.1-.354Z" clip-rule="evenodd" />
            </svg>
          </span>
          <span class="text-lg font-semibold tracking-tight">Lightning Weather</span>
        </a>
        <span class="text-sm text-slate-500 hidden sm:inline">Hyper-local forecasts in a flash</span>
      </div>
    </header>

    <main class="container mx-auto px-5 py-10">
      <%= yield %>
    </main>

    <footer class="container mx-auto px-5 py-8 text-center text-xs text-slate-500">
      Powered by Google Maps &amp; Open-Meteo. Cached for 30 minutes per ZIP.
    </footer>
  </body>
</html>
